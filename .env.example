# ─── Discord ───────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CLIENT_ID=your_discord_application_id
DISCORD_GUILD_ID=your_discord_server_id

# ─── Google Gemini ─────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Scheduling ────────────────────────────────────────
# Heures de publication (format 24h, séparées par des virgules)
PUBLISH_HOURS=9,13,18
# Intervalle de scraping en heures
SCRAPE_INTERVAL_HOURS=6
# Nombre maximum de news postées par jour
MAX_DAILY_NEWS=5

# ─── Options ───────────────────────────────────────────
# Langue des résumés (fr ou en)
SUMMARY_LANGUAGE=fr
# Timezone pour le scheduler
TIMEZONE=Europe/Paris
# Niveau de log (debug, info, warn, error)
LOG_LEVEL=info
